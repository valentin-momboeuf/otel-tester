# ─── otel-tester environment variables ───────────────────────────────
# Copy this file or use one of the presets in envs/
#
# Usage: docker compose --env-file envs/.env.local up
#
# See README.md for details on each backend profile.

# ─── Collector Configuration ─────────────────────────────────────────
# Which collector config to load (config.yaml or config-datadog.yaml)
COLLECTOR_CONFIG=config.yaml

# ─── OTLP Exporter Settings ─────────────────────────────────────────
# Endpoint for the otlphttp exporter (ignored when using datadog exporter)
OTLP_ENDPOINT=http://localhost:4318

# Auth header value for OTLP requests (e.g. "Bearer <token>" or "Basic <base64>")
# Leave empty for unauthenticated backends
OTLP_AUTH_HEADER=""

# ─── Pipeline Exporter Selection ────────────────────────────────────
# YAML array of exporters for each pipeline, e.g. [otlphttp, debug]
# Available: debug | otlphttp | prometheus | datadog
TRACES_EXPORTERS=[debug]
METRICS_EXPORTERS=[debug]
LOGS_EXPORTERS=[debug]

# ─── Debug Exporter ─────────────────────────────────────────────────
# Verbosity for the debug exporter: basic | normal | detailed
DEBUG_VERBOSITY=basic

# ─── Resource Attributes ────────────────────────────────────────────
DEPLOYMENT_ENV=otel-tester

# ─── Compose Profiles ───────────────────────────────────────────────
# Comma-separated list of profiles to activate
# Available: local (Jaeger+Prometheus+Grafana), generators (otelgen), load-test (k6)
# COMPOSE_PROFILES=local

# ─── Port Overrides ─────────────────────────────────────────────────
# COLLECTOR_GRPC_PORT=4317
# COLLECTOR_HTTP_PORT=4318
# ENVOY_PORT=8080

# ─── Datadog (only for .env.datadog) ────────────────────────────────
# DD_API_KEY=<your-datadog-api-key>
# DD_SITE=datadoghq.com

# ─── Elastic APM (only for .env.elastic) ────────────────────────────
# ELASTIC_APM_ENDPOINT=https://your-apm-server:8200
# ELASTIC_APM_TOKEN=your-secret-token

# ─── Grafana Cloud (only for .env.grafana) ──────────────────────────
# GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
# GRAFANA_API_TOKEN=base64-encoded-instance-id:api-key

# ─── k6 Load Test Settings ──────────────────────────────────────────
# K6_SCRIPT=smoke.js
# K6_VUS=5
# K6_DURATION=30s
