# Local backend: Jaeger (traces) + Prometheus (metrics) + Grafana (dashboards)
COLLECTOR_CONFIG=config.yaml
OTLP_ENDPOINT=http://jaeger:4318
OTLP_AUTH_HEADER=""
TRACES_EXPORTERS=[otlphttp, debug]
METRICS_EXPORTERS=[prometheus, debug]
LOGS_EXPORTERS=[debug]
DEBUG_VERBOSITY=basic
DEPLOYMENT_ENV=local
COMPOSE_PROFILES=local
