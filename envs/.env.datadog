# Datadog backend (uses native datadog exporter)
# Set DD_API_KEY before use
COLLECTOR_CONFIG=config-datadog.yaml
DD_API_KEY=<your-datadog-api-key>
DD_SITE=datadoghq.com
OTLP_ENDPOINT=http://localhost:4318
OTLP_AUTH_HEADER=""
TRACES_EXPORTERS=[datadog, debug]
METRICS_EXPORTERS=[datadog, debug]
LOGS_EXPORTERS=[datadog, debug]
DEBUG_VERBOSITY=basic
DEPLOYMENT_ENV=datadog
