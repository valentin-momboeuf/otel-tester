# Grafana Cloud backend (Tempo + Mimir + Loki via OTLP)
# Set GRAFANA_OTLP_ENDPOINT and GRAFANA_API_TOKEN before use
COLLECTOR_CONFIG=config.yaml
OTLP_ENDPOINT=${GRAFANA_OTLP_ENDPOINT}
OTLP_AUTH_HEADER=Basic ${GRAFANA_API_TOKEN}
TRACES_EXPORTERS=[otlphttp]
METRICS_EXPORTERS=[otlphttp]
LOGS_EXPORTERS=[otlphttp]
DEBUG_VERBOSITY=basic
DEPLOYMENT_ENV=grafana
