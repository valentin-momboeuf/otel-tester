# Elastic APM backend
# Set ELASTIC_APM_ENDPOINT and ELASTIC_APM_TOKEN before use
COLLECTOR_CONFIG=config.yaml
OTLP_ENDPOINT=${ELASTIC_APM_ENDPOINT}
OTLP_AUTH_HEADER=Bearer ${ELASTIC_APM_TOKEN}
TRACES_EXPORTERS=[otlphttp]
METRICS_EXPORTERS=[otlphttp]
LOGS_EXPORTERS=[otlphttp]
DEBUG_VERBOSITY=basic
DEPLOYMENT_ENV=elastic
