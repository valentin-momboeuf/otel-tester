# ─── otel-tester backend profile template ────────────────────────────
# Copy this file to .env.<profile-name> and fill in your values.
# Usage: docker compose --env-file envs/.env.<profile-name> up

COLLECTOR_CONFIG=config.yaml
OTLP_ENDPOINT=http://localhost:4318
OTLP_AUTH_HEADER=""
TRACES_EXPORTERS=[debug]
METRICS_EXPORTERS=[debug]
LOGS_EXPORTERS=[debug]
DEBUG_VERBOSITY=basic
DEPLOYMENT_ENV=otel-tester
